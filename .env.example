# .env.example - 复制此文件为 .env 并填入你的 API Key

# NVIDIA API（可调用 GLM、Kimi、DeepSeek、MiniMax 等模型）
NVIDIA_API_KEY="your-nvidia-api-key-here"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"

# 模型选择（优先使用 Kimi）
# 可选：google/gemma-2-27b-it, deepseek-ai/DeepSeek-V3, minimax/MiniMax-M2.2-natively
DEFAULT_MODEL="nvidia/nim-meta/llama-3.3-70b-instruct"

# Kimi 模型（优先）
KIMI_MODEL="moonshotai/kimi-k2-0711-preview"
